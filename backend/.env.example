# Backend environment configuration — copy to .env and fill in.

# Port the Express API listens on
PORT=5001

# MongoDB connection string.
# Must be a REPLICA SET (Atlas, or local `--replSet`) — multi-document
# transactions used for atomic billing require it.
#   Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/hotel_pos
#   Local:  mongodb://127.0.0.1:27017/hotel_pos?replicaSet=rs0
MONGODB_URI=mongodb://127.0.0.1:27017/hotel_pos?replicaSet=rs0

# Secret used to sign JWTs stored in the http-only cookie. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-secret

# development | production  (production enables Secure cookies)
NODE_ENV=development
